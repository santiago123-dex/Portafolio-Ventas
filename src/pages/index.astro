---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Landing Studio | Landing pages para microempresas y negocios";
const description =
  "Disenamos landing pages para microempresas y negocios que buscan verse profesionales, ganar confianza y captar mas clientes desde Google, redes y anuncios.";

const reviews = [
  {
    quote: "Ahora explicamos mejor lo que hacemos y la gente nos contacta mas.",
    author: "Laura Pineda",
    role: "Spa estetico",
  },
  {
    quote:
      "La pagina se ve profesional y nos ayuda mucho cuando enviamos trafico.",
    author: "Diego Parra",
    role: "Consultoria contable",
  },
  {
    quote: "Quedo clara, bonita y lista para mostrar nuestros servicios.",
    author: "Mariana Gil",
    role: "Reposteria",
  },
];

const reviewTrack = [...reviews, ...reviews];

const projects = [
  {
    name: "SoundHealth",
    type: "Bienestar",
    url: "https://soundhealth.vercel.app",
    description:
      "Pagina informativa para una microempresa de poder terapeutico, enfocada en mostrar como el yoga, el sonido y la vibracion pueden ayudar a recuperar la armonia del cuerpo y la mente.",
  },
  {
    name: "Barber Studio",
    type: "Servicios",
    url: "https://barber-topaz-chi.vercel.app/",
    description:
      "Landing page para una barberia, con un diseño moderno y masculino, enfocada en mostrar los servicios, precios y generar confianza para convertir visitantes en clientes.",
  },
];
---

<BaseLayout title={title} description={description}>
  <main
    class="relative mx-auto w-full max-w-[1280px] px-4 py-4 sm:px-6 sm:py-5 md:px-10"
  >
    <section
      class="relative z-10 overflow-hidden px-2 py-10 sm:px-4 sm:py-14 md:px-8 md:py-20"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-[-8%] top-0 h-[220px] w-[220px] rounded-full bg-[radial-gradient(circle,rgba(139,92,246,0.16),transparent_70%)] blur-3xl sm:h-[320px] sm:w-[320px]"
      >
      </div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute right-[-2%] bottom-[10%] h-[320px] w-[320px] rounded-full bg-[radial-gradient(circle,rgba(139,92,246,0.18),transparent_70%)] blur-3xl sm:h-[420px] sm:w-[420px]"
      >
      </div>

      <div class="relative mx-auto max-w-[1120px]">
        <div class="max-w-[700px] text-left">
          <div class="w-full flex flex-col text-left items-left">
            <h1
              class="text-[clamp(2.9rem,10vw,5.6rem)] font-semibold leading-[0.92] tracking-[-0.07em] text-[#7C3AED]"
            >
              <span class="block">Sitio web para impulsar tu</span>
              <span class="block">negocio.</span>
            </h1>
            <p
              class="mt-7 text-[1.04rem] leading-8 text-slate-600 sm:text-[1.18rem] sm:leading-9"
            >
              Disenamos sitios web informativos personalizados hechos para
              ayudarte a obtener mayor visibilidad y llegar a mas clientes.
              Ideal para emprendedores y negocios locales que quieren expandir
              su presencia en internet.
            </p>

            <div class="mt-9 flex flex-col gap-3 sm:flex-row">
              <a
                class="inline-flex min-h-14 items-center justify-center rounded-[18px] bg-[linear-gradient(135deg,#7C3AED,#8B5CF6)] px-8 py-4 text-base font-semibold text-white shadow-[0_18px_35px_rgba(124,58,237,0.3)] transition-transform hover:-translate-y-0.5"
                href="#contact"
              >
                Quiero mi sitio web
              </a>
              <a
                class="inline-flex min-h-14 items-center justify-center rounded-[18px] border border-[#d6ddf1] bg-white/90 px-8 py-4 text-base font-semibold text-slate-700 shadow-[0_12px_30px_rgba(148,163,184,0.08)] transition-colors hover:border-[#8B5CF6]/35 hover:text-[#8B5CF6]"
                href="#projects"
              >
                Ver ejemplos
              </a>
            </div>
          </div>
        </div>

        <aside
          class="relative mx-auto mt-12 w-full max-w-[740px] rounded-[34px] border border-white/80 bg-white/88 p-5 shadow-[0_35px_120px_rgba(139,92,246,0.14)] backdrop-blur-sm sm:mt-14 sm:p-6 md:p-7"
        >
          <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-12 -bottom-10 h-24 rounded-full bg-[radial-gradient(circle,rgba(139,92,246,0.26),transparent_72%)] blur-2xl"
          >
          </div>
          <div
            class="relative rounded-[28px] bg-[linear-gradient(180deg,#fffefe_0%,#f8f4ff_100%)] px-5 py-5 sm:px-7 sm:py-6"
          >
            <p
              class="text-[0.82rem] font-extrabold uppercase tracking-[0.28em] text-[#6D28D9]"
            >
              Crecimiento Digital
            </p>
            <h2
              class="mt-3 text-[clamp(1.9rem,5vw,3rem)] font-semibold leading-none tracking-[-0.05em] text-slate-900"
            >
              Tu negocio en movimiento
            </h2>

            <div
              class="mt-6 rounded-[24px] border border-[#ece6ff] bg-white p-4 sm:p-5"
            >
              <div
                class="relative overflow-hidden rounded-[20px] bg-[linear-gradient(180deg,#ffffff_0%,#faf7ff_100%)] px-3 pb-4 pt-6 sm:px-5 sm:pb-5 sm:pt-8"
              >
                <div
                  class="absolute inset-x-0 top-0 h-28 bg-[radial-gradient(circle_at_50%_0%,rgba(139,92,246,0.12),transparent_70%)]"
                >
                </div>

                <svg
                  viewBox="0 0 430 280"
                  class="relative z-10 mx-auto h-auto w-full max-w-[460px]"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <ellipse cx="83" cy="223" rx="34" ry="13" fill="#D8CEF8"
                  ></ellipse>
                  <ellipse cx="157" cy="240" rx="34" ry="13" fill="#D8CEF8"
                  ></ellipse>
                  <ellipse cx="335" cy="188" rx="28" ry="11" fill="#D8CEF8"
                  ></ellipse>

                  <ellipse cx="83" cy="214" rx="32" ry="12" fill="#6D28D9"
                  ></ellipse>
                  <ellipse cx="83" cy="206" rx="32" ry="12" fill="#8B5CF6"
                  ></ellipse>
                  <ellipse cx="83" cy="198" rx="32" ry="12" fill="#6D28D9"
                  ></ellipse>
                  <ellipse cx="83" cy="190" rx="32" ry="12" fill="#8B5CF6"
                  ></ellipse>
                  <path
                    d="M83 182C100 182 115 187 115 194V198C115 205 100 210 83 210C66 210 51 205 51 198V194C51 187 66 182 83 182Z"
                    fill="#5B21B6"></path>
                  <text
                    x="83"
                    y="201"
                    text-anchor="middle"
                    font-size="18"
                    font-weight="700"
                    fill="#D9C8FF">$</text
                  >

                  <ellipse cx="157" cy="231" rx="32" ry="12" fill="#6D28D9"
                  ></ellipse>
                  <ellipse cx="157" cy="223" rx="32" ry="12" fill="#8B5CF6"
                  ></ellipse>
                  <ellipse cx="157" cy="215" rx="32" ry="12" fill="#6D28D9"
                  ></ellipse>
                  <path
                    d="M157 207C174 207 189 212 189 219V223C189 230 174 235 157 235C140 235 125 230 125 223V219C125 212 140 207 157 207Z"
                    fill="#5B21B6"></path>
                  <text
                    x="157"
                    y="226"
                    text-anchor="middle"
                    font-size="18"
                    font-weight="700"
                    fill="#D9C8FF">$</text
                  >

                  <ellipse cx="335" cy="180" rx="26" ry="10" fill="#6D28D9"
                  ></ellipse>
                  <ellipse cx="335" cy="173" rx="26" ry="10" fill="#8B5CF6"
                  ></ellipse>
                  <ellipse cx="335" cy="166" rx="26" ry="10" fill="#6D28D9"
                  ></ellipse>
                  <path
                    d="M335 159C349 159 361 163 361 169V173C361 179 349 183 335 183C321 183 309 179 309 173V169C309 163 321 159 335 159Z"
                    fill="#5B21B6"></path>
                  <text
                    x="335"
                    y="177"
                    text-anchor="middle"
                    font-size="15"
                    font-weight="700"
                    fill="#D9C8FF">$</text
                  >

                  <path d="M154 214V149L190 128V214" fill="#5B21B6"></path>
                  <path
                    d="M154 149L190 128L207 139L171 160L154 149Z"
                    fill="#7C3AED"></path>
                  <path d="M190 128L207 139V225L190 214V128Z" fill="#8B5CF6"
                  ></path>

                  <path d="M214 214V108L253 84V214" fill="#8B5CF6"></path>
                  <path
                    d="M214 108L253 84L274 97L235 121L214 108Z"
                    fill="#C4B5FD"></path>
                  <path d="M253 84L274 97V227L253 214V84Z" fill="#A78BFA"
                  ></path>

                  <path d="M278 214V57L318 32V214" fill="#6D28D9"></path>
                  <path d="M278 57L318 32L339 45L299 70L278 57Z" fill="#8B5CF6"
                  ></path>
                  <path d="M318 32L339 45V227L318 214V32Z" fill="#A78BFA"
                  ></path>

                  <path
                    d="M71 156L156 70L184 98L285 17"
                    stroke="#7C3AED"
                    stroke-width="11"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M261 20L285 17L279 41"
                    stroke="#7C3AED"
                    stroke-width="11"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
            </div>

            <p
              class="mt-5 max-w-[48ch] text-[0.98rem] leading-8 text-slate-600"
            >
              Un sitio web bien estructurado te ayuda a mostrar confianza,
              atraer nuevos clientes y mantener un avance constante.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <section
      class="relative z-10 mt-15 mx-4 overflow-hidden rounded-[38px] border border-white/70 bg-white/82 px-4 py-6 shadow-[0_28px_90px_rgba(139,92,246,0.08)] backdrop-blur-sm sm:px-7 sm:py-8 md:px-10 md:py-10"
      id="reviews"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_12%_18%,rgba(79,110,247,0.06),transparent_22%),radial-gradient(circle_at_88%_84%,rgba(139,92,246,0.12),transparent_24%)]"
      >
      </div>

      <div class="relative mb-7 gap-4 text-left md:gap-5 md:items-start">
        <div>
          <p
            class="mb-3 text-[0.78rem] font-extrabold uppercase tracking-[0.22em] text-[#7C3AED]"
          >
            Reseñas
          </p>
          <h2
            class="text-[clamp(1.9rem,8vw,4rem)] font-semibold leading-[0.95] tracking-[-0.05em] text-slate-900 text-balance"
          >
            Clientes que ya dieron el salto digital
          </h2>
        </div>
      </div>

      <div
        class="group relative overflow-hidden rounded-[26px] border border-[#ece6ff] bg-white/55 p-0.5 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)]"
      >
        <div
          class="pointer-events-none absolute inset-y-0 left-0 z-10 hidden w-16 bg-[linear-gradient(90deg,rgba(255,255,255,1),rgba(255,255,255,0))] sm:block"
        >
        </div>
        <div
          class="pointer-events-none absolute inset-y-0 right-0 z-10 hidden w-16 bg-[linear-gradient(270deg,rgba(255,255,255,1),rgba(255,255,255,0))] sm:block"
        >
        </div>

        <div
          class="flex w-max -translate-x-[158px] gap-2 rounded-[24px] bg-[linear-gradient(180deg,rgba(255,255,255,0.7),rgba(250,247,255,0.86))] p-3 sm:translate-x-0 sm:gap-4 sm:p-5 sm:animate-[review-marquee_24s_linear_infinite] sm:group-hover:[animation-play-state:paused]"
        >
          {
            reviewTrack.map((review) => (
              <article class="flex min-h-[224px] w-[296px] shrink-0 flex-col rounded-[24px] border border-[#ece6ff] bg-white px-4 py-4 shadow-[0_14px_30px_rgba(139,92,246,0.08)] sm:w-[320px] sm:px-5 sm:py-5">
                <div class="mb-5 flex gap-1 text-lg text-[#7C3AED]">
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                </div>

                <p class="m-0 text-[0.98rem] leading-8 text-slate-600">
                  "{review.quote}"
                </p>

                <footer class="mt-auto flex items-center gap-3 border-t border-[#ece6ff] pt-5">
                  <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[linear-gradient(135deg,#7C3AED,#EC4899)] text-base font-semibold text-white">
                    {review.author.charAt(0)}
                  </div>
                  <div class="grid gap-0.5">
                    <strong class="text-[1rem] text-slate-800">
                      {review.author}
                    </strong>
                    <span class="text-sm text-slate-500">{review.role}</span>
                  </div>
                </footer>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="projects"
      class="surface-card relative z-10 mt-15 rounded-4xl p-4 sm:p-5 md:p-6"
    >
      <div
        class="mb-6 grid gap-4 text-center md:grid-cols-[minmax(0,1fr)_minmax(220px,320px)] md:items-end md:text-left"
      >
        <div class="mx-auto md:mx-0">
          <p
            class="mb-3 text-[0.75rem] font-extrabold uppercase tracking-[0.14em] text-accent"
          >
            Proyectos
          </p>
          <h2
            class="text-[clamp(2rem,7vw,2.25rem)] font-semibold leading-[1.06] tracking-[-0.03em] text-balance"
          >
            Ejemplos pensados para negocios de servicios.
          </h2>
        </div>
        <p class="m-0 text-[0.96rem] leading-6 text-muted">
          Cada landing se adapta a tu oferta y cliente ideal.
        </p>
      </div>

      <div class="grid gap-4">
        {
          projects.map((project) => (
            <article class="surface-soft overflow-hidden p-3 md:p-4">
              <div class="mb-4 overflow-hidden rounded-[20px] border border-line bg-white">
                <div class="flex items-center gap-2 border-b border-line px-4 py-3">
                  <span class="h-3 w-3 rounded-full bg-slate-300" />
                  <span class="h-3 w-3 rounded-full bg-slate-300" />
                  <span class="h-3 w-3 rounded-full bg-slate-300" />
                </div>
                <div class="h-[190px] overflow-hidden bg-white sm:h-[300px] md:h-[340px]">
                  <iframe
                    src={project.url}
                    title={`Preview del proyecto ${project.name}`}
                    class="h-[380px] w-[210%] origin-top-left scale-[0.47] bg-white sm:h-[500px] sm:w-[175%] sm:scale-[0.57] md:h-[566px] md:w-[166.667%] md:scale-[0.6]"
                    loading="lazy"
                  />
                </div>
              </div>

              <div class="grid gap-2 text-center md:text-left">
                <p class="m-0 text-[0.76rem] font-extrabold uppercase tracking-widest text-accent">
                  {project.type}
                </p>
                <h3 class="text-[1.2rem] leading-7 sm:text-[1.35rem]">
                  {project.name}
                </h3>
                <p class="m-0 max-w-[70ch] text-[0.94rem] leading-7 text-muted sm:text-[0.96rem]">
                  {project.description}
                </p>
                <a
                  href={project.url}
                  target="_blank"
                  rel="noreferrer"
                  class="mt-2 text-sm font-semibold text-[#8B5CF6] underline-offset-4 hover:underline"
                >
                  Ver proyecto
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section
      id="contact"
      class="relative z-10 mb-15 mt-15 grid gap-4 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]"
    >
      <div
        class="surface-card rounded-4xl p-4 text-center sm:p-5 md:p-6 md:text-left"
      >
        <p
          class="mb-3 text-[0.75rem] font-extrabold uppercase tracking-[0.14em] text-accent"
        >
          Contacto
        </p>
        <h2
          class="max-w-[12ch] text-[clamp(1.9rem,8vw,3rem)] font-semibold leading-[1.06] tracking-[-0.03em] text-balance"
        >
          Hablemos de tu landing.
        </h2>
        <p class="mt-4 text-[0.96rem] leading-6 text-muted">
          Estos son las maneras en que nos puedes contactar. Si quieres una
          landing personalizada para tu negocio, solo tienes que escribirnos y
          te guiaremos en el proceso.
        </p>
        <div class="flex flex-col gap-2">
          <a
            class="mt-5 inline-block text-[1.05rem] font-extrabold text-accent"
            href="mailto:hola@landingstudio.com"
          >
            santiagofajardomorales17@gmail.com
          </a>
          <a class="">
            Telefono: <span class="text-[1.05rem] font-extrabold text-accent"
              >+57 3136728159</span
            >
          </a>
        </div>
      </div>

      <form
        class="surface-card grid gap-4 rounded-4xl p-4 sm:p-5 md:p-6"
        aria-label="Formulario de contacto"
      >
        <label class="grid gap-2 text-sm text-muted">
          Nombre
          <input
            class="w-full rounded-2xl border border-line-strong bg-white px-4 py-3 text-text outline-none transition-colors focus:border-[rgba(75,93,147,0.35)]"
            type="text"
            name="name"
            placeholder="Tu nombre"
          />
        </label>
        <label class="grid gap-2 text-sm text-muted">
          Email
          <input
            class="w-full rounded-2xl border border-line-strong bg-white px-4 py-3 text-text outline-none transition-colors focus:border-[rgba(75,93,147,0.35)]"
            type="email"
            name="email"
            placeholder="tu@negocio.com"
          />
        </label>
        <label class="grid gap-2 text-sm text-muted">
          Tu negocio
          <textarea
            class="w-full rounded-2xl border border-line-strong bg-white px-4 py-3 text-text outline-none transition-colors focus:border-[rgba(75,93,147,0.35)]"
            name="message"
            rows="4"
            placeholder="Que vendes y que objetivo tienes."></textarea>
        </label>
        <button
          class="inline-flex min-h-12 w-full items-center justify-center rounded-full bg-accent px-5 py-3 text-sm font-bold text-white shadow-[0_16px_32px_rgba(79,110,247,0.22)] transition-transform hover:-translate-y-0.5 hover:bg-[#8B5CF6] sm:w-auto"
          type="submit"
        >
          Solicitar informacion
        </button>
      </form>
    </section>
  </main>
</BaseLayout>

<style>
  @keyframes review-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - 0.5rem));
    }
  }
</style>
