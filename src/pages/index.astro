---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Landing Studio | Landing pages para microempresas y negocios";
const description =
  "Disenamos landing pages para microempresas y negocios que buscan verse profesionales, ganar confianza y captar mas clientes desde Google, redes y anuncios.";

const reviews = [
  {
    quote: "Ahora explicamos mejor lo que hacemos y la gente nos contacta mas.",
    author: "Laura Pineda",
    role: "Spa estetico",
  },
  {
    quote: "La pagina se ve profesional y nos ayuda mucho cuando enviamos trafico.",
    author: "Diego Parra",
    role: "Consultoria contable",
  },
  {
    quote: "Quedo clara, bonita y lista para mostrar nuestros servicios.",
    author: "Mariana Gil",
    role: "Reposteria",
  },
];

const reviewTrack = [...reviews, ...reviews];

const projects = [
  {
    name: "SoundHealth",
    type: "Bienestar",
    url: "https://soundhealth.vercel.app",
    description:
      "Pagina informativa para una microempresa de poder terapeutico, enfocada en mostrar como el yoga, el sonido y la vibracion pueden ayudar a recuperar la armonia del cuerpo y la mente.",
  },
  {
    name:  "Barber Studio",
    type: "Servicios",
    url: "https://barber-topaz-chi.vercel.app/",
    description:
    "Landing page para una barberia, con un diseño moderno y masculino, enfocada en mostrar los servicios, precios y generar confianza para convertir visitantes en clientes.",
  }
];
---

<BaseLayout title={title} description={description}>
  <main class="relative mx-auto w-[min(1160px,calc(100%-1rem))] px-0 py-4 sm:py-5 md:w-[min(1160px,calc(100%-2rem))]">
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-0 bg-white blur-[80px]"
      style={`background-image:
        radial-gradient(
          circle at top center,
          rgba(70, 130, 180, 0.5),
          transparent 70%
        );
        background-repeat: no-repeat;`}
    ></div>

    <header class="surface-card relative z-10 mb-4 flex flex-wrap items-center justify-center gap-3 rounded-[28px] px-4 py-4 backdrop-blur-sm sm:justify-between sm:rounded-full">
      <a class="flex items-center gap-3 font-semibold" href="/" aria-label="Landing Studio inicio">
        <span class="flex h-9 w-9 items-center justify-center rounded-2xl bg-accent text-sm text-white">LS</span>
        <span>Landing Studio</span>
      </a>

      <nav aria-label="Navegacion principal" class="flex flex-wrap justify-center gap-3 text-sm text-muted sm:gap-4 md:gap-5">
        <a class="transition-colors hover:text-text" href="#reviews">Reseñas</a>
        <a class="transition-colors hover:text-text" href="#projects">Proyectos</a>
        <a class="transition-colors hover:text-text" href="#contact">Contacto</a>
      </nav>
    </header>

    <section class="surface-card relative z-10 grid items-center gap-6 overflow-hidden rounded-4xl p-4 sm:p-5 md:grid-cols-[minmax(0,1fr)_minmax(360px,0.95fr)] md:p-7">
      <div class="flex flex-col justify-center px-1 py-2 md:pr-3">
        <p class="mb-3 text-[0.75rem] font-extrabold uppercase tracking-[0.14em] text-accent">
          Landings Para Negocios
        </p>
        <h1 class="text-[clamp(2.2rem,9vw,4.5rem)] font-semibold leading-[0.98] tracking-[-0.05em] text-balance">
          Explica tu servicio en segundos y consigue mas clientes.
        </h1>
        <p class="mt-4 max-w-[42ch] text-[0.96rem] leading-7 text-muted sm:mt-5 sm:text-[1rem]">
          Diseno profesional, estructura clara y enfoque real en conversion para negocios de servicios.
        </p>

        <div class="mt-5 flex flex-wrap items-center gap-3 text-sm">
          <span class="rounded-full bg-accent-soft px-3 py-1.5 font-semibold text-accent">
            4.9/5 valoracion media
          </span>
          <span class="text-muted">Usado por negocios que quieren verse mas profesionales.</span>
        </div>

        <div class="my-6 flex flex-col gap-3 sm:my-7 sm:flex-row sm:flex-wrap">
          <a
            class="inline-flex min-h-14 w-full items-center justify-center rounded-xl bg-[#FF6B4A] px-7 py-4 text-base font-semibold text-white shadow-[0_10px_25px_rgba(0,0,0,0.15)] transition-transform hover:-translate-y-0.5 hover:bg-[#ff5a35] sm:w-auto"
            href="#contact"
          >
            Quiero mi landing
          </a>
          <a
            class="inline-flex min-h-12 w-full items-center justify-center rounded-full border border-line-strong bg-white px-5 py-3 text-sm font-bold text-text transition-transform hover:-translate-y-0.5 hover:border-[#8B5CF6]/30 hover:text-[#8B5CF6] sm:w-auto"
            href="#projects"
          >
            Ver trabajos
          </a>
        </div>

        <div class="mb-5 flex flex-col gap-y-2 text-sm text-muted sm:flex-row sm:flex-wrap sm:gap-x-4">
          <span>✔ Entrega rapida</span>
          <span>✔ Optimizada para conversiones</span>
          <span>✔ Diseno profesional</span>
        </div>

        <div class="grid gap-3 md:grid-cols-3">
          <article class="surface-soft flex min-h-29.5 flex-col justify-center gap-2 p-4">
            <strong class="block text-[0.95rem]">Mas confianza</strong>
            <span class="block text-sm leading-6 text-muted">Tu negocio se ve serio y ordenado.</span>
          </article>
          <article class="surface-soft flex min-h-29.5 flex-col justify-center gap-2 p-4">
            <strong class="block text-[0.95rem]">Mas claridad</strong>
            <span class="block text-sm leading-6 text-muted">Tu servicio se entiende rapido.</span>
          </article>
          <article class="surface-soft flex min-h-29.5 flex-col justify-center gap-2 p-4">
            <strong class="block text-[0.95rem]">Mas contactos</strong>
            <span class="block text-sm leading-6 text-muted">CTA y formularios listos para vender.</span>
          </article>
        </div>
      </div>

      <aside class="surface-soft grid h-auto content-center gap-5 rounded-[30px] p-4 sm:p-5 md:h-[85%]" aria-label="Resumen del servicio">
        <div class="flex gap-2">
          <span class="h-3 w-3 rounded-full bg-slate-300"></span>
          <span class="h-3 w-3 rounded-full bg-slate-300"></span>
          <span class="h-3 w-3 rounded-full bg-slate-300"></span>
        </div>

        <div class="grid gap-4">
          <div class="surface-soft overflow-hidden rounded-3xl bg-[radial-gradient(circle,rgba(79,110,247,0.15),transparent)] p-3">
            <div class="rounded-[20px] border border-line bg-white p-3 shadow-[0_30px_80px_rgba(0,0,0,0.12)] sm:-rotate-2 sm:p-4">
              <div class="mb-4 flex flex-wrap items-center justify-between gap-2 border-b border-line pb-3">
                <div>
                  <p class="m-0 text-[0.68rem] font-extrabold uppercase tracking-[0.12em] text-[#8B5CF6]">
                    Preview Landing
                  </p>
                  <strong class="mt-1 block text-sm">Vista principal</strong>
                </div>
                <div class="rounded-full bg-accent-soft px-3 py-1 text-[0.72rem] font-semibold text-accent">
                  Activa
                </div>
              </div>

              <div class="grid gap-3">
                <div class="rounded-[18px] bg-[linear-gradient(135deg,#4F6EF7,#8B5CF6)] p-4 text-white">
                  <p class="m-0 text-[0.7rem] uppercase tracking-[0.14em] text-white/70">Hero</p>
                  <p class="mt-2 max-w-[18ch] text-base font-semibold leading-6 sm:text-lg">
                    Tu servicio explicado en pocos segundos.
                  </p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    <span class="rounded-full bg-white px-3 py-1 text-[0.72rem] font-semibold text-[#8B5CF6]">
                      CTA
                    </span>
                    <span class="rounded-full border border-white/30 px-3 py-1 text-[0.72rem] font-semibold">
                      Contacto
                    </span>
                  </div>
                </div>

                <div class="grid gap-3 sm:grid-cols-[1.2fr_0.8fr]">
                  <div class="rounded-[18px] border border-line bg-slate-50 p-3">
                    <p class="m-0 text-[0.68rem] uppercase tracking-[0.12em] text-muted">Conversion</p>
                    <strong class="mt-2 block text-2xl font-semibold text-text">+32%</strong>
                    <span class="mt-1 block text-sm text-muted">Mas contactos desde la pagina</span>
                  </div>
                  <div class="rounded-[18px] border border-line bg-slate-50 p-3">
                    <p class="m-0 text-[0.68rem] uppercase tracking-[0.12em] text-muted">Mobile</p>
                    <div class="mt-2 rounded-[14px] border border-line bg-white p-2">
                      <div class="mx-auto h-1.5 w-8 rounded-full bg-slate-200"></div>
                      <div class="mt-2 h-12 rounded-[10px] bg-accent-soft"></div>
                      <div class="mt-2 h-2 rounded-full bg-slate-200"></div>
                      <div class="mt-1 h-2 w-4/5 rounded-full bg-slate-200"></div>
                    </div>
                  </div>
                </div>

                <div class="rounded-[18px] border border-dashed border-[#8B5CF6]/25 bg-[#8B5CF6]/5 px-4 py-3">
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div>
                      <p class="m-0 text-[0.68rem] uppercase tracking-[0.12em] text-[#8B5CF6]">CTA principal</p>
                      <strong class="mt-1 block text-sm">Boton visible desde el primer scroll</strong>
                    </div>
                    <span class="rounded-lg bg-white px-3 py-2 text-sm font-semibold text-[#8B5CF6] shadow-sm">
                      Contactar
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <p class="m-0 text-[0.74rem] font-extrabold uppercase tracking-[0.14em] text-accent">
            Que Incluye Tu Landing
          </p>

          <div class="grid gap-3 sm:grid-cols-2">
            <article class="surface-soft grid min-h-[132px] content-center gap-2.5 p-4 text-center">
              <span class="text-xs font-extrabold text-accent">01</span>
              <strong class="text-base">Mensaje claro</strong>
              <p class="m-0 text-sm leading-6 text-muted">Explicamos tu servicio en segundos.</p>
            </article>
            <article class="surface-soft grid min-h-[132px] content-center gap-2.5 p-4 text-center">
              <span class="text-xs font-extrabold text-accent">02</span>
              <strong class="text-base">Prueba social</strong>
              <p class="m-0 text-sm leading-6 text-muted">Reseñas y casos que suman confianza.</p>
            </article>
            <article class="surface-soft grid min-h-[132px] content-center gap-2.5 p-4 text-center">
              <span class="text-xs font-extrabold text-accent">03</span>
              <strong class="text-base">Contacto directo</strong>
              <p class="m-0 text-sm leading-6 text-muted">WhatsApp, formulario y CTA visibles.</p>
            </article>
            <article class="surface-soft grid min-h-[132px] content-center gap-2.5 p-4 text-center">
              <span class="text-xs font-extrabold text-accent">04</span>
              <strong class="text-base">Base SEO</strong>
              <p class="m-0 text-sm leading-6 text-muted">Lista para indexar mejor en buscadores.</p>
            </article>
          </div>
        </div>
      </aside>
    </section>

    <section id="reviews" class="surface-card relative z-10 mt-15 rounded-4xl p-4 sm:p-5 md:p-6">
      <div class="mb-6 grid gap-4 md:grid-cols-[minmax(0,1fr)_minmax(220px,320px)] md:items-end">
        <div>
          <p class="mb-3 text-[0.75rem] font-extrabold uppercase tracking-[0.14em] text-accent">Reseñas</p>
          <h2 class="text-[clamp(2rem,7vw,2.25rem)] font-semibold leading-[1.06] tracking-[-0.03em] text-balance">
            Negocios que ahora se presentan mejor.
          </h2>
        </div>
        <p class="m-0 text-[0.96rem] leading-6 text-muted">Menos ruido. Mas claridad. Mas confianza.</p>
      </div>

      <div class="group relative overflow-hidden">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 hidden w-16 bg-[linear-gradient(90deg,rgba(246,245,240,1),rgba(246,245,240,0))] sm:block"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 hidden w-16 bg-[linear-gradient(270deg,rgba(246,245,240,1),rgba(246,245,240,0))] sm:block"></div>

        <div
          class="flex w-max gap-3 sm:gap-4 animate-[review-marquee_24s_linear_infinite] group-hover:[animation-play-state:paused]"
        >
          {reviewTrack.map((review, index) => (
            <article
              class="surface-soft flex min-h-[190px] w-[260px] shrink-0 flex-col justify-between gap-5 p-4 sm:w-[280px] sm:p-5 md:w-[320px]"
            >
              <p class="m-0 text-[0.94rem] leading-7 sm:text-[0.96rem]">{review.quote}</p>
              <footer class="grid gap-1">
                <strong>{review.author}</strong>
                <span class="text-sm text-muted">{review.role}</span>
              </footer>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="surface-card relative z-10 mt-15 rounded-4xl p-4 sm:p-5 md:p-6">
      <div class="mb-6 grid gap-4 md:grid-cols-[minmax(0,1fr)_minmax(220px,320px)] md:items-end">
        <div>
          <p class="mb-3 text-[0.75rem] font-extrabold uppercase tracking-[0.14em] text-accent">Proyectos</p>
          <h2 class="text-[clamp(2rem,7vw,2.25rem)] font-semibold leading-[1.06] tracking-[-0.03em] text-balance">
            Ejemplos pensados para negocios de servicios.
          </h2>
        </div>
        <p class="m-0 text-[0.96rem] leading-6 text-muted">Cada landing se adapta a tu oferta y cliente ideal.</p>
      </div>

      <div class="grid gap-4">
        {projects.map((project) => (
          <article class="surface-soft overflow-hidden p-3 md:p-4">
            <div class="mb-4 overflow-hidden rounded-[20px] border border-line bg-white">
              <div class="flex items-center gap-2 border-b border-line px-4 py-3">
                <span class="h-3 w-3 rounded-full bg-slate-300"></span>
                <span class="h-3 w-3 rounded-full bg-slate-300"></span>
                <span class="h-3 w-3 rounded-full bg-slate-300"></span>
              </div>
              <div class="h-[220px] overflow-hidden bg-white sm:h-[300px] md:h-[340px]">
                <iframe
                  src={project.url}
                  title={`Preview del proyecto ${project.name}`}
                  class="h-[440px] w-[190%] origin-top-left scale-[0.52] bg-white sm:h-[500px] sm:w-[175%] sm:scale-[0.57] md:h-[566px] md:w-[166.667%] md:scale-[0.6]"
                  loading="lazy"
                ></iframe>
              </div>
            </div>

            <div class="grid gap-2">
              <p class="m-0 text-[0.76rem] font-extrabold uppercase tracking-widest text-accent">
                {project.type}
              </p>
              <h3 class="text-[1.2rem] leading-7 sm:text-[1.35rem]">{project.name}</h3>
              <p class="m-0 max-w-[70ch] text-[0.94rem] leading-7 text-muted sm:text-[0.96rem]">
                {project.description}
              </p>
              <a
                href={project.url}
                target="_blank"
                rel="noreferrer"
                class="mt-2 text-sm font-semibold text-[#8B5CF6] underline-offset-4 hover:underline"
              >
                Ver proyecto
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="contact" class="relative z-10 mb-15 mt-15 grid gap-4 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <div class="surface-card rounded-4xl p-4 sm:p-5 md:p-6">
        <p class="mb-3 text-[0.75rem] font-extrabold uppercase tracking-[0.14em] text-accent">Contacto</p>
        <h2 class="max-w-[12ch] text-[clamp(2.1rem,8vw,3rem)] font-semibold leading-[1.06] tracking-[-0.03em] text-balance">
          Hablemos de tu landing.
        </h2>
        <p class="mt-4 text-[0.96rem] leading-6 text-muted">
          Estos son las maneras en que nos puedes contactar. Si quieres una landing personalizada para tu negocio, solo tienes que escribirnos y te guiaremos en el proceso.
        </p>
        <div class="flex flex-col gap-2">
          <a class="mt-5 inline-block text-[1.05rem] font-extrabold text-accent" href="mailto:hola@landingstudio.com">
            santiagofajardomorales17@gmail.com
          </a>
          <a class="">
            Telefono: <span class="text-[1.05rem] font-extrabold text-accent">+57 3136728159</span>
          </a>

        </div>
      </div>

      <form class="surface-card grid gap-4 rounded-4xl p-4 sm:p-5 md:p-6" aria-label="Formulario de contacto">
        <label class="grid gap-2 text-sm text-muted">
          Nombre
          <input
            class="w-full rounded-2xl border border-line-strong bg-white px-4 py-3 text-text outline-none transition-colors focus:border-[rgba(75,93,147,0.35)]"
            type="text"
            name="name"
            placeholder="Tu nombre"
          />
        </label>
        <label class="grid gap-2 text-sm text-muted">
          Email
          <input
            class="w-full rounded-2xl border border-line-strong bg-white px-4 py-3 text-text outline-none transition-colors focus:border-[rgba(75,93,147,0.35)]"
            type="email"
            name="email"
            placeholder="tu@negocio.com"
          />
        </label>
        <label class="grid gap-2 text-sm text-muted">
          Tu negocio
          <textarea
            class="w-full rounded-2xl border border-line-strong bg-white px-4 py-3 text-text outline-none transition-colors focus:border-[rgba(75,93,147,0.35)]"
            name="message"
            rows="4"
            placeholder="Que vendes y que objetivo tienes."
          ></textarea>
        </label>
        <button
          class="inline-flex min-h-12 w-full items-center justify-center rounded-full bg-accent px-5 py-3 text-sm font-bold text-white shadow-[0_16px_32px_rgba(79,110,247,0.22)] transition-transform hover:-translate-y-0.5 hover:bg-[#8B5CF6] sm:w-auto"
          type="submit"
        >
          Solicitar informacion
        </button>
      </form>
    </section>
  </main>
</BaseLayout>

<style>


  @keyframes review-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - 0.5rem));
    }
  }
</style>
