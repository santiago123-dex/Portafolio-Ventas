---
import ContactSection from "../components/sections/home/ContactSection.astro";
import HomeHero from "../components/sections/home/HomeHero.astro";
import ProjectsSection from "../components/sections/home/ProjectsSection.astro";
import ReviewsSection from "../components/sections/home/ReviewsSection.astro";
import { homePageContent } from "../features/home/content";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title={homePageContent.seo.title}
  description={homePageContent.seo.description}
>
  <main class="relative mx-auto w-full max-w-[1440px] px-4 py-4 sm:px-6 sm:py-5 md:px-10">
    <HomeHero content={homePageContent.hero} />
    <ReviewsSection reviews={homePageContent.reviews} />
    <ProjectsSection projects={homePageContent.projects} />
    <ContactSection contact={homePageContent.contact} />
  </main>
</BaseLayout>
